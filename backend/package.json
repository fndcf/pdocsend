{
  "name": "imobi-whatsapp-backend",
  "version": "1.0.0",
  "description": "Backend do Imobi WhatsApp - Leitura de PDFs e envio de mensagens",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "cross-env LOCAL_DEV=true ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:emulators": "cross-env LOCAL_DEV=true GOOGLE_CLOUD_PROJECT=pdocsend GCLOUD_PROJECT=pdocsend FIRESTORE_EMULATOR_HOST=127.0.0.1:8280 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9299 ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed:tenant": "ts-node scripts/seed-tenant.ts",
    "seed:ativar": "ts-node scripts/ativar-usuario.ts"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@google-cloud/tasks": "^5.1.0",
    "@types/busboy": "^1.5.4",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.1",
    "helmet": "^7.1.0",
    "pdf-lib": "^1.17.1",
    "pdf.js-extract": "^0.2.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
