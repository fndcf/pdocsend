# Firebase
FB_PROJECT_ID=pdocsend
NODE_ENV=development

# CORS - origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://pdocsend.web.app,https://pdocsend.firebaseapp.com

# Criptografia Z-API (32 bytes = 64 caracteres hex)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Em produção: firebase functions:secrets:set ZAPI_ENCRYPTION_KEY
ZAPI_ENCRYPTION_KEY=

# Servidor local (usado apenas com npm run dev)
LOCAL_DEV=true
PORT=5000
