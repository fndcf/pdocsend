rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Negar tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Users - apenas o próprio usuário pode ler
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Tenants - apenas membros do tenant podem ler
    match /tenants/{tenantId} {
      allow read: if request.auth != null;

      // Lotes e envios - apenas via backend (Cloud Functions)
      match /lotes/{loteId} {
        allow read: if request.auth != null;

        match /envios/{envioId} {
          allow read: if request.auth != null;
        }
      }

      // Índice de deduplicação
      match /imoveis_enviados/{hash} {
        allow read: if request.auth != null;
      }
    }
  }
}
