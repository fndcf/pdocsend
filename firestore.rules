rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Negar tudo por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Função helper: verificar se usuário pertence ao tenant
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTenantMember(tenantId) {
      return request.auth != null && getUserData().tenantId == tenantId;
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().role == "superadmin";
    }

    // Users - apenas o próprio usuário pode ler
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Tenants - apenas membros do tenant ou superadmin
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId) || isSuperAdmin();

      // Lotes - apenas membros do tenant ou superadmin
      match /lotes/{loteId} {
        allow read: if isTenantMember(tenantId) || isSuperAdmin();

        // Envios - apenas membros do tenant ou superadmin
        match /envios/{envioId} {
          allow read: if isTenantMember(tenantId) || isSuperAdmin();
        }
      }

      // Índice de deduplicação - apenas membros do tenant ou superadmin
      match /imoveis_enviados/{hash} {
        allow read: if isTenantMember(tenantId) || isSuperAdmin();
      }
    }
  }
}
