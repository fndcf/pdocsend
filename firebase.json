{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "backend",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "src/**/*.test.ts",
      "src/__tests__/**"
    ]
  },
  "emulators": {
    "auth": {
      "port": 9299
    },
    "functions": {
      "port": 5003
    },
    "firestore": {
      "port": 8280
    },
    "ui": {
      "enabled": true,
      "port": 4002
    }
  }
}
